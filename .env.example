# R runtime (required on the server where this MCP runs — not on the client)
RSCRIPT_PATH=Rscript
RSCRIPT_TIMEOUT_SEC=60

# Artifacts directory — where R scripts write PNG files (default: artifacts/ in repo root)
# OPENAIR_ARTIFACTS_DIR=/var/data/openair-artifacts

# FastMCP transport: stdio (Claude Desktop / local) or http (remote / mcp-remote)
OPENAIR_MCP_TRANSPORT=http
OPENAIR_MCP_PORT=8001

# Max raw bytes for load_series_from_upload (default 1 MB)
# OPENAIR_INGEST_MAX_BYTES=1048576
